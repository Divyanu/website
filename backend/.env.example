PORT=4000
# Conversion Access Token (Events Manager → Conversions API). If this is a JWT that includes `aid`, account id can be auto-detected.
REDDIT_ACCESS_TOKEN=your_conversion_access_token
# Pixel ID (Events Manager) — attached in event_metadata for tracing.
REDDIT_PIXEL_ID=your_pixel_id
# Reddit Ads account id for the CAPI URL path (often t2_xxx). Required unless your JWT contains `aid` / `lid`.
REDDIT_AD_ACCOUNT_ID=t2_your_account_id
# Optional: Reddit test event code when test_mode is true
# REDDIT_TEST_EVENT_CODE=
