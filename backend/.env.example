PORT=4000
# Conversion Access Token (Events Manager → Conversions API). Never expose to the frontend.
REDDIT_ACCESS_TOKEN=your_conversion_access_token
# Optional alias for the same token:
# REDDIT_CONVERSION_ACCESS_TOKEN=your_conversion_access_token
# Pixel ID from Events Manager — server injects into CAPI JSON (not read from browser).
REDDIT_PIXEL_ID=your_pixel_id
#
# REDDIT_AD_ACCOUNT_ID is NOT required by this backend. If you still see errors mentioning it,
# redeploy the latest backend code from this repo.
