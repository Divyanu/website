PORT=4000
# Reddit Ads account ID (Events Manager / Ads dashboard; may look like t2_xxxxx)
REDDIT_AD_ACCOUNT_ID=your_ad_account_id
# Conversion Access Token (Events Manager → Conversions API → generate token)
REDDIT_ACCESS_TOKEN=your_conversion_access_token
# Optional: copied from Events Manager; added to event_metadata for debugging
REDDIT_PIXEL_ID=
REDDIT_TEST_EVENT_CODE=
